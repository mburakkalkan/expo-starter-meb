{
  "name": "expo-starter-meb",
  "main": "expo-router/entry",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "preinstall": "node ./scripts/set-cert.js",
    "android": "node -r ./scripts/set-cert.js ./node_modules/expo/bin/cli start --android",
    "dev-eas-build-all": "eas build --profile development",
    "dev-eas-build-android": "eas build --platform android --profile development",
    "dev-eas-build-ios": "eas build --platform ios --profile development",
    "dev-eas-build-web": "eas build --platform web --profile development",
    "dev-local-build-all": "eas build --profile development --local",
    "dev-local-build-android": "eas build --platform android --profile development --local",
    "dev-local-build-ios": "eas build --platform ios --profile development --local",
    "dev-local-build-web": "eas build --platform web --profile development --local",
    "expo-install": "node -r ./scripts/set-cert.js ./node_modules/expo/bin/cli install",
    "ios": "node -r ./scripts/set-cert.js ./node_modules/expo/bin/cli start --ios",
    "lint": "node -r ./scripts/set-cert.js ./node_modules/expo/bin/cli lint",
    "local": "node -r ./scripts/set-cert.js ./node_modules/expo/bin/cli start --localhost",
    "offline": "node -r ./scripts/set-cert.js ./node_modules/expo/bin/cli start --offline",
    "prod-eas-build-all": "eas build --profile production",
    "prod-eas-build-android": "eas build --platform android --profile production",
    "prod-eas-build-ios": "eas build --platform ios --profile production",
    "prod-eas-build-web": "eas build --platform web --profile production",
    "prod-local-build-all": "eas build --profile production --local",
    "prod-local-build-android": "eas build --platform android --profile production --local",
    "prod-local-build-ios": "eas build --platform ios --profile production --local",
    "prod-local-build-web": "eas build --platform web --profile production --local",
    "reset-project": "node ./scripts/reset-project.js",
    "start": "node -r ./scripts/set-cert.js ./node_modules/expo/bin/cli start",
    "tunnel": "node -r ./scripts/set-cert.js ./node_modules/expo/bin/cli start --tunnel",
    "web": "node -r ./scripts/set-cert.js ./node_modules/expo/bin/cli start --web"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/elements": "^2.9.10",
    "@react-navigation/native": "^7.1.33",
    "axios": "^1.14.0",
    "babel-preset-expo": "^55.0.13",
    "expo": "~55.0.9",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.19",
    "expo-device": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-glass-effect": "~55.0.8",
    "expo-image": "~55.0.6",
    "expo-linking": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
    "expo-system-ui": "~55.0.11",
    "expo-web-browser": "~55.0.10",
    "nativewind": "^4.2.3",
    "pocketbase": "^0.26.8",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  }
}
